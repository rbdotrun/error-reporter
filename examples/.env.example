# Copy this file to .env (gitignored) before `dip up`. The same token is
# seeded as an IngestionCredential on the host AND used as the bearer
# token by the client's HttpSink — so the credential dance is automated
# and `dip up` brings up a working end-to-end demo with no manual steps.
#
# Token format: `rbreport_v1_` + 32 bytes urlsafe_base64. In real
# operator use, generate via `IngestionCredential.issue!` and store the
# returned plaintext in your secret manager — never reuse the example
# value below.

ERROR_REPORTER_TOKEN=rbreport_v1_EXAMPLE_DO_NOT_USE_IN_PRODUCTION_AAAAAAAAAAAAAAAAAA
