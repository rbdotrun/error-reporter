# Examples — local-only state from `dip up`. Lockfiles are
# regenerated per-machine; runtime dirs are bind-mount artefacts.
examples/.env
examples/*/Gemfile.lock
examples/*/tmp/
examples/*/log/
# Generated by db:migrate inside the host container; the engine
# migrations are the source of truth, schema.rb dumped here is just
# a runtime side-effect of the bind mount.
examples/host/db/schema.rb

